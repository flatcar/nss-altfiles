#!/bin/bash
# configure.sh — Generate config.mk for the nss-altfiles build.
#
# Mimics autotools configure conventions so build systems that forward all
# configure flags work without modification.  Unrecognized options are silently
# ignored for that reason.

set -euo pipefail

readonly CONFIG_MK="config.mk"
readonly MAKEFILE="Makefile"

# Capture the original invocation before the parsing loop consumes positional parameters.
tmp=$(mktemp "${CONFIG_MK}.XXXXXX")
trap 'rm -f "${tmp}"' EXIT
echo "# autogenerated by: ${0} $*" >"$tmp"

usage() {
    cat <<-EOF
        usage: ${0} [OPTIONS]

        Options:
          --help                    This help message.
          --prefix=PATH             Installation path prefix [default: /]
          --libdir=PATH             Library directory [default: PREFIX/lib/]
          --datadir=PATH            Runtime data directory [default: PREFIX/lib/]
          --with-module-name=NAME   Alternate module name [default: altfiles]
          --with-types=TYPE1,TYPE2,...
                                    NSS types the module will handle.
                                    Use "all" to support all types.
                                    [default: pwd,grp,initgroups]

        NSS types and their data files:

          rpc        \$DATADIR/rpc
          proto      \$DATADIR/protocols
          hosts      \$DATADIR/hosts
          network    \$DATADIR/networks
          service    \$DATADIR/services
          pwd        \$DATADIR/passwd
          grp        \$DATADIR/group
          initgroups \$DATADIR/group
          spwd       \$DATADIR/shadow
          sgrp       \$DATADIR/gshadow

        Compiler flags are taken from the environment:

          CFLAGS
          LDFLAGS

        NOTE: Unrecognized options are silently ignored for compatibility with
        build systems that forward all configure flags (autotools convention).
EOF
}

# ---------------------------------------------------------------------------
types=''

while [ $# -gt 0 ]; do
    case "$1" in
        --help)
            usage
            exit 0
            ;;
        --prefix=*)
            val="${1#--prefix=}"
            echo "Setting PREFIX=${val}"
            echo "PREFIX := ${val}" >>"$tmp"
            shift
            ;;
        --libdir=*)
            val="${1#--libdir=}"
            val="${val%%/}/"
            echo "Setting LIBDIR=${val}"
            echo "LIBDIR := ${val}" >>"$tmp"
            shift
            ;;
        --datadir=*)
            val="${1#--datadir=}"
            val="${val%%/}/"
            echo "Setting DATADIR=${val}"
            echo "DATADIR := ${val}" >>"$tmp"
            shift
            ;;
        --with-module-name=*)
            val="${1#--with-module-name=}"
            echo "Setting MODULE_NAME=${val}"
            echo "MODULE_NAME := ${val}" >>"$tmp"
            shift
            ;;
        --with-types=*)
            # check Makefile later
            types="${1#--with-types=}"
            shift
            ;;
        *) shift ;; # silently ignore; autotools convention
    esac
done

# ---------------------------------------------------------------------------
if [ "$types" = "all" ]; then
    if [ ! -f "$MAKEFILE" ]; then
        echo "${0}: error: --with-types=all requires $MAKEFILE to be present" >&2
        exit 1
    fi
    resolved=$(sed -n 's/.*$(HANDLE_\([a-z]\+\)).*/\1/p' "$MAKEFILE" | grep -v XXX | sort -u | paste -s -d ',')
    if [ -z "$resolved" ]; then
        echo "${0}: error: no HANDLE_* variables found in $MAKEFILE" >&2
        exit 1
    fi
    types="$resolved"
fi

if [ -n "$types" ]; then
    echo "Setting TYPES=${types}"
    # Clear the Makefile defaults before asserting the caller-supplied set.
    # This must be updated by hand if the default change
    echo "HANDLE_pwd :=" >>"$tmp"
    echo "HANDLE_grp :=" >>"$tmp"
    echo "HANDLE_initgroups :=" >>"$tmp"
    printf '%s' ",${types}" | sed 's/,\([^,]\+\)/HANDLE_\1 := 1\n/g' >>"$tmp"
fi

# ---------------------------------------------------------------------------
mv "$tmp" "$CONFIG_MK"
trap - EXIT

echo "config.mk written"
